import User from "../models/User.js";
import FixedSchedule from "../models/FixedSchedule.js";
import Appointment from "../models/Appointment.js";

const SERVICE_KEY_TO_NAME = {
  PE: "Primera evaluación presencial",
  EP: "Entrenamiento Personal",
  RA: "Rehabilitación Activa",
  RF: "Reeducación Funcional",
  KD: "Kinefilaxia Deportiva",
  NUT: "Nutrición",
};

const SERVICE_KEYS = new Set(Object.keys(SERVICE_KEY_TO_NAME));
const THERAPY_KEYS = new Set(["RA", "RF", "KD"]);
const EP_CAP = 12;
const THERAPY_SHARED_CAP = 8;
const TZ = "America/Argentina/Buenos_Aires";

function pad2(n) {
  return String(n).padStart(2, "0");
}

function stripAccents(value) {
  return String(value || "")
    .normalize("NFD")
    .replace(/[\u0300-\u036f]/g, "");
}

function normalizeServiceKey(value) {
  const raw = String(value || "").trim();
  if (!raw) return "";

  const upper = stripAccents(raw).toUpperCase().trim();
  if (upper === "AR") return "RA";
  if (upper === "KINEDEPO" || upper === "KINE-DEPO") return "KD";
  if (SERVICE_KEYS.has(upper)) return upper;

  const s = stripAccents(raw).toLowerCase().trim();
  if (s.includes("primera") && s.includes("evaluacion")) return "PE";
  if (s.includes("entrenamiento") && s.includes("personal")) return "EP";
  if (s.includes("rehabilitacion") && s.includes("activa")) return "RA";
  if (s.includes("reeducacion") && s.includes("funcional")) return "RF";
  if (s.includes("kinefilaxia") || (s.includes("kine") && s.includes("deport"))) return "KD";
  if (s.includes("nutric")) return "NUT";
  return "";
}

function arParts(date = new Date()) {
  const parts = new Intl.DateTimeFormat("en-CA", {
    timeZone: TZ,
    year: "numeric",
    month: "2-digit",
    day: "2-digit",
  }).formatToParts(date);

  const out = {};
  for (const part of parts) out[part.type] = part.value;
  return {
    year: Number(out.year),
    month: Number(out.month),
    day: Number(out.day),
    ymd: `${out.year}-${out.month}-${out.day}`,
    monthKey: `${out.year}-${out.month}`,
  };
}

function ymdFromParts(year, month, day) {
  return `${year}-${pad2(month)}-${pad2(day)}`;
}

function dateFromYmd(dateStr) {
  const [y, m, d] = String(dateStr || "").split("-").map(Number);
  return new Date(y, (m || 1) - 1, d || 1, 12, 0, 0, 0);
}

function weekdayMondayFirst(dateStr) {
  const js = dateFromYmd(dateStr).getDay();
  return js === 0 ? 7 : js;
}

function daysInMonth(year, month) {
  return new Date(year, month, 0).getDate();
}

function isBusinessDay(year, month, day) {
  const js = new Date(year, month - 1, day, 12, 0, 0, 0).getDay();
  return js !== 0 && js !== 6;
}

function firstBusinessDay(year, month) {
  for (let d = 1; d <= 7; d += 1) {
    if (isBusinessDay(year, month, d)) return d;
  }
  return 1;
}

function monthRange(year, month) {
  return {
    from: ymdFromParts(year, month, 1),
    to: ymdFromParts(year, month, daysInMonth(year, month)),
  };
}

function addUserHistory(user, item = {}) {
  user.history = Array.isArray(user.history) ? user.history : [];
  user.history.push({
    action: String(item.action || "").trim() || "monthly_automation",
    title: String(item.title || "").trim(),
    message: String(item.message || "").trim(),
    serviceKey: String(item.serviceKey || "").trim(),
    serviceName: String(item.serviceName || "").trim(),
    service: String(item.service || item.serviceName || "").trim(),
    qty: Number(item.qty || 0) || 0,
    createdAt: new Date(),
  });
}

function recalcUserCredits(user) {
  const now = new Date();
  const lots = Array.isArray(user.creditLots) ? user.creditLots : [];

  user.credits = lots.reduce((acc, lot) => {
    const exp = lot.expiresAt ? new Date(lot.expiresAt) : null;
    if (exp && exp <= now) return acc;
    return acc + Number(lot.remaining || 0);
  }, 0);
}

function expireAvailableCredits(user, monthKey) {
  let expired = 0;
  user.creditLots = Array.isArray(user.creditLots) ? user.creditLots : [];

  for (const lot of user.creditLots) {
    const remaining = Number(lot.remaining || 0);
    if (remaining <= 0) continue;
    lot.remaining = 0;
    expired += remaining;
  }

  if (expired > 0) {
    addUserHistory(user, {
      action: "monthly_credits_expired",
      title: `Vencimiento mensual de créditos (${monthKey})`,
      message: `Se vencieron ${expired} crédito(s) disponibles al iniciar el nuevo mes.`,
      qty: expired,
    });
  }
}

function buildMonthOccurrencesForSchedule(schedule, year, month) {
  const out = [];
  const max = daysInMonth(year, month);
  const items = Array.isArray(schedule.items) ? schedule.items : [];
  const range = monthRange(year, month);

  for (let d = 1; d <= max; d += 1) {
    const date = ymdFromParts(year, month, d);
    if (date < range.from || date > range.to) continue;
    if (schedule.startDate && date < String(schedule.startDate)) continue;
    if (schedule.endDate && date > String(schedule.endDate)) continue;

    const weekday = weekdayMondayFirst(date);
    for (const item of items) {
      if (Number(item?.weekday || 0) !== weekday) continue;
      const time = String(item?.time || "").slice(0, 5);
      if (!time) continue;
      out.push({ date, time });
    }
  }

  return out.sort((a, b) => `${a.date} ${a.time}`.localeCompare(`${b.date} ${b.time}`));
}

async function canCreateFixedAppointment({ date, time, serviceKey, userId }) {
  const existingMine = await Appointment.findOne({
    user: userId,
    date,
    time,
    status: "reserved",
  }).lean();
  if (existingMine) return { ok: false, reason: "USER_ALREADY_HAS_SLOT" };

  const existingAtSlot = await Appointment.find({
    date,
    time,
    status: "reserved",
  }).lean();

  const sk = normalizeServiceKey(serviceKey);
  if (sk === "EP") {
    const count = existingAtSlot.filter((ap) => normalizeServiceKey(ap.serviceKey || ap.service) === "EP").length;
    return count < EP_CAP
      ? { ok: true }
      : { ok: false, reason: "EP_CAP_REACHED" };
  }

  if (THERAPY_KEYS.has(sk)) {
    const count = existingAtSlot.filter((ap) => THERAPY_KEYS.has(normalizeServiceKey(ap.serviceKey || ap.service))).length;
    return count < THERAPY_SHARED_CAP
      ? { ok: true }
      : { ok: false, reason: "THERAPY_CAP_REACHED" };
  }

  return { ok: true };
}

async function generateFixedAppointmentsForSchedule(schedule, { year, month, monthKey, todayYmd }) {
  if (String(schedule.lastGeneratedMonthKey || "") === monthKey) {
    return { created: 0, skipped: 0 };
  }

  const serviceKey = normalizeServiceKey(schedule.serviceKey || schedule.service);
  if (!serviceKey) return { created: 0, skipped: 0 };

  const occurrences = buildMonthOccurrencesForSchedule(schedule, year, month)
    .filter((occ) => occ.date >= todayYmd);

  let created = 0;
  let skipped = 0;

  for (const occ of occurrences) {
    const existing = await Appointment.findOne({
      fixedScheduleId: schedule._id,
      date: occ.date,
      time: occ.time,
      status: "reserved",
    }).lean();
    if (existing) {
      skipped += 1;
      continue;
    }

    const allowed = await canCreateFixedAppointment({
      date: occ.date,
      time: occ.time,
      serviceKey,
      userId: schedule.user,
    });

    if (!allowed.ok) {
      skipped += 1;
      continue;
    }

    await Appointment.create({
      user: schedule.user,
      date: occ.date,
      time: occ.time,
      serviceKey,
      service: SERVICE_KEY_TO_NAME[serviceKey] || schedule.service || serviceKey,
      status: "reserved",
      assignedManually: true,
      fixedScheduleId: schedule._id,
      monthlyRolloverMonthKey: monthKey,
      createdByRole: "admin",
      createdByUser: schedule.createdBy || null,
      notes: schedule.notes || "Turno fijo mensual generado automáticamente.",
    });

    created += 1;
  }

  schedule.lastGeneratedMonthKey = monthKey;
  await schedule.save();

  return { created, skipped };
}

async function expireCreditsOncePerMonth({ monthKey }) {
  const users = await User.find({ role: { $in: ["client", "guest"] } });
  let usersUpdated = 0;

  for (const user of users) {
    user.monthlyAutomation = user.monthlyAutomation || {};
    if (String(user.monthlyAutomation.lastMonthlyResetMonthKey || "") === monthKey) {
      continue;
    }

    expireAvailableCredits(user, monthKey);
    user.monthlyAutomation.lastMonthlyResetMonthKey = monthKey;
    user.monthlyAutomation.lastRunAt = new Date();
    recalcUserCredits(user);
    await user.save();
    usersUpdated += 1;
  }

  return { usersUpdated };
}

async function generateFixedAppointmentsForMonth({ year, month, monthKey, todayYmd }) {
  const range = monthRange(year, month);
  const activeSchedules = await FixedSchedule.find({
    active: true,
    startDate: { $lte: range.to },
    endDate: { $gte: range.from },
  });

  let schedulesProcessed = 0;
  let appointmentsCreated = 0;
  let appointmentsSkipped = 0;

  for (const schedule of activeSchedules) {
    const result = await generateFixedAppointmentsForSchedule(schedule, {
      year,
      month,
      monthKey,
      todayYmd,
    });

    schedulesProcessed += 1;
    appointmentsCreated += Number(result.created || 0);
    appointmentsSkipped += Number(result.skipped || 0);
  }

  return { schedulesProcessed, appointmentsCreated, appointmentsSkipped };
}

export async function runMonthlyRollover({ now = new Date(), force = false } = {}) {
  const { year, month, day, ymd, monthKey } = arParts(now);
  const firstBiz = firstBusinessDay(year, month);
  const shouldRun = force || day >= firstBiz;

  const result = {
    ok: true,
    todayAR: ymd,
    monthKey,
    firstBusinessDay: firstBiz,
    creditsReset: null,
    fixedAppointments: null,
  };

  if (!shouldRun) return result;

  result.creditsReset = await expireCreditsOncePerMonth({ monthKey });
  result.fixedAppointments = await generateFixedAppointmentsForMonth({
    year,
    month,
    monthKey,
    todayYmd: ymd,
  });

  return result;
}

export function startMonthlyRolloverScheduler({ everyMinutes = 60 } = {}) {
  const intervalMs = Math.max(10, Number(everyMinutes || 60)) * 60 * 1000;

  async function tick() {
    try {
      const result = await runMonthlyRollover();
      console.log("[MONTHLY] tick", result);
    } catch (err) {
      console.error("[MONTHLY] tick error:", err?.message || err);
    }
  }

  console.log("[MONTHLY] scheduler starting", { everyMinutes, mode: "monthly-reset-fixed-appointments" });
  setTimeout(tick, 5000);
  setInterval(tick, intervalMs);
}
